<Project>
  <PropertyGroup>
    <RevitCliVersion>2.3.0</RevitCliVersion>
    <Version Condition="'$(Version)' == ''">$(RevitCliVersion)</Version>
    <Authors>RevitCli Contributors</Authors>
    <Company>RevitCli Contributors</Company>
    <Copyright>Copyright (c) RevitCli Contributors</Copyright>

    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>CS1591;NU1605</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
  </PropertyGroup>
</Project>
